            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alex Johnson\",\n  \"email\": \"alex.j@email.com\",\n  \"password\": \"demo123\",\n  \"role\": \"candidate\"\n}"
            }
          }
        },
